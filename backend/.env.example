PORT=5001
# Production DB: set this in your hosting provider (Render) dashboard.
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@your-db-host:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@your-db-host:5432/postgres?sslmode=require"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="replace-with-a-secure-secret"
JWT_EXPIRES_IN="8h"
FRONTEND_URL="http://localhost:5173"
USE_REAL_GATEWAY=false
PAYMENT_GATEWAY=fake

# Supabase storage configuration. Set these only when using Supabase uploads.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=your-bucket-name

# Copy this file to .env for local development and fill values.
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h
FRONTEND_URL=http://localhost:5173
USE_REAL_GATEWAY=false
PAYMENT_GATEWAY=fake
