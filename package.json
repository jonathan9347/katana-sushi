{
  "private": true,
  "scripts": {
    "build": "cd backend && npm install && npm run build",
    "start": "cd backend && npm run start",
    "prisma:generate": "cd backend && npx prisma generate --schema=prisma/schema.prisma --no-engine",
    "prisma:push": "cd backend && npx prisma db push --schema=prisma/schema.prisma"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
